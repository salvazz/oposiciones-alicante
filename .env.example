# Configuración de Email para Notificaciones
# Copia este archivo como .env y configura tus credenciales

# SMTP Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Email Credentials
SENDER_EMAIL=tu-email@gmail.com
SENDER_PASSWORD=tu-app-password

